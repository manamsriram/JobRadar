# Gmail SMTP (use an App Password, not your login password; requires 2FA)
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
ALERT_TO=you@gmail.com

# Hunter.io contact lookup — on-demand only (POST /api/jobs/{id}/contacts),
# never fired from the poll loop. 1 credit per company (limit=1, Hunter's own
# top-ranked contact); results are cached per-domain in data/company_contacts.json
# so re-applying to the same company costs nothing further. Any company works,
# not just curated ones — uncurated companies get a best-effort domain guess
# (flagged via domain_guessed in the response).
HUNTER_API_KEY=
# Free plan = 50 credits/month, billed 1 credit per email actually returned
# (verified against Hunter's own API docs — not a per-request charge).
HUNTER_MONTHLY_CALL_CAP=50

# Required: shared secret authenticating POST /api/ingest from the GitHub
# Actions Playwright offload (playwright_scraper.yml). Generate a random value
# (e.g. `openssl rand -hex 32`) and set the same value as the repo's
# INGEST_TOKEN secret, with INGEST_URL pointing at this host.
INGEST_TOKEN=

# Shared secret with the Vercel proxy (frontend/api/[...path].ts) — set the
# same value in both places. Blank disables the check (local dev default).
INTERNAL_KEY=

# Persistent JSON state dir. /data is the mounted volume in Docker; override for
# local dev (e.g. DATA_DIR=./data).
DATA_DIR=/data

# AI second-pass resume-fit gate — tries providers in this order, falling
# through to the next once one's daily cap is hit. Leave AI_PROVIDERS at just
# "openrouter" (default) for the original single-provider behavior.
# https://openrouter.ai/keys
AI_PROVIDERS=openrouter,groq
OPENROUTER_API_KEY=
# Must end in ":free" — ai_match.py refuses paid OpenRouter model ids.
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# 50/day on OpenRouter's free baseline; raise once the account has ever
# loaded $10 in credit (bumps the free-tier cap to 1000/day).
OPENROUTER_DAILY_CALL_CAP=50

# Groq (free tier, OpenAI-compatible) — fallback once OpenRouter's cap is
# hit. Leave GROQ_API_KEY blank to skip this provider entirely.
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Groq's free tier is throttled per-model (30 requests/min, 500K tokens/day
# for llama-3.1-8b-instant per console.groq.com/docs/rate-limits) rather than
# a flat daily call count — this is a conservative request-count proxy, tune
# against your own usage.
GROQ_DAILY_CALL_CAP=100

# Tuning (defaults shown)
POLL_INTERVAL_SECONDS=300
FUNDING_CHECK_INTERVAL=3600
ALERT_INTERVAL_SECONDS=14400
ALERT_DIGEST_SIZE=5
PURGE_AFTER_DAYS=3
MAX_POSTED_AGE_DAYS=7
MAX_YEARS_EXPERIENCE=2
CYCLE_RETRY_BUDGET=20
