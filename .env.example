# Gmail SMTP (use an App Password, not your login password; requires 2FA)
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
ALERT_TO=you@gmail.com

# Hunter.io contact enrichment (free plan, 50 credits/mo) — optional, tier-1 only
HUNTER_API_KEY=

# Phase 2 only: shared secret authenticating POST /api/ingest from the
# GitHub Actions Playwright offload. Leave blank in Phase 1.
INGEST_TOKEN=

# Persistent JSON state dir. /data is the mounted volume in Docker; override for
# local dev (e.g. DATA_DIR=./data).
DATA_DIR=/data

# Tuning (defaults shown)
POLL_INTERVAL_SECONDS=300
FUNDING_CHECK_INTERVAL=3600
PURGE_AFTER_DAYS=3
MAX_POSTED_AGE_DAYS=14
